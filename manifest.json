{
   "action": {
      "default_icon": {
         "16": "icon16.png",
         "32": "icon32.png",
         "48": "icon48.png",
         "128": "icon128.png"
      },
      "default_title": "GridPlayer"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content_script.js" ],
      "matches": [ "https://*.youtube.com/*", "https://*.nicovideo.jp/*", "https://*.vimeo.com/*", "https://*.tiktok.com/*", "https://*.twitch.tv/*", "https://*.pornhub.com/*", "https://*.rule34video.com/*", "https://*.ashemaletube.com/*", "https://*.xgroovy.com/*", "https://*.xhamster.com/*", "https://*.xhamster.desi/*", "https://*.xhamster.one/*" ],
      "run_at": "document_start"
   } ],
   "description": "Multi screen video player: watch multiple YouTube, Twitch, TikTok, Vimeo & Niconico videos at once in a grid.",
   "host_permissions": [ "*://www.youtube.com/*", "*://*.youtube.com/*", "*://*.googlevideo.com/*", "*://*.ytimg.com/*", "*://*.ggpht.com/*", "*://*.google.com/*", "*://*.doubleclick.net/*", "*://*.googleadservices.com/*", "*://*.nicovideo.jp/*", "*://embed.nicovideo.jp/*", "*://*.vimeo.com/*", "*://player.vimeo.com/*", "*://*.tiktok.com/*", "*://*.twitch.tv/*", "*://clips.twitch.tv/*", "*://player.twitch.tv/*", "*://*.pornhub.com/*", "*://*.rule34video.com/*", "*://*.ashemaletube.com/*", "*://*.xgroovy.com/*", "*://*.xhamster.com/*", "*://*.xhamster.desi/*", "*://*.xhamster.one/*", "*://*.xhcdn.com/*", "*://*.xhstrm.net/*" ],
   "icons": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
   },
   "manifest_version": 3,
   "name": "GridPlayer - Multi Screen Video Player",
   "permissions": [ "sidePanel", "tabs", "storage", "declarativeNetRequest", "declarativeNetRequestWithHostAccess", "clipboardRead" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "version": "2.0.1"
}
